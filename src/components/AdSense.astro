---
interface Props {
  type: 'banner' | 'square' | 'in-feed';
}

const { type } = Astro.props;

const styles = {
  banner: 'w-full h-[120px]',
  square: 'w-[300px] h-[250px] mx-auto',
  'in-feed': 'w-full min-h-[150px] bg-gradient-to-b from-surface to-bg'
};
---

<div class={`relative flex flex-col items-center justify-center rounded-lg border border-dashed border-white/10 bg-surface my-12 overflow-hidden ${styles[type]}`}>
  <div class="absolute top-2 text-[8px] text-text-dim tracking-[0.3em] font-bold">
    PUBLICIDAD
  </div>
  <div class="text-text-muted italic text-sm text-center px-4">
    <p>Espacio optimizado para AdSense ({type})</p>
  </div>
</div>
