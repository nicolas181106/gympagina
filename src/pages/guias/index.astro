---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import AdSense from '../../components/AdSense.astro';
import { BookOpen, Clock, Activity, Flame } from 'lucide-astro';

const guides = [
  {
    title: "Guía de Inicio: El MicroGym de 2 metros cuadrados",
    description: "Todo lo que necesitas saber para empezar a entrenar en casa hoy mismo sin sacrificar tu salón.",
    icon: Activity,
    slug: "inicio-microgym"
  },
  {
    title: "Rutina FullBody: Máxima Fuerza en 3 días",
    description: "Un programa diseñado para ganar masa muscular con el mínimo equipamiento posible.",
    icon: Flame,
    slug: "rutina-fullbody"
  },
  {
    title: "Gestión de Espacio: Cómo organizar tu rack",
    description: "Trucos y consejos para que tu equipo de pesas desaparezca cuando termines de entrenar.",
    icon: Clock,
    slug: "gestion-espacio"
  },
  {
    title: "Suplementación Esencial para el Atleta Casero",
    description: "¿Qué suplementos realmente marcan la diferencia cuando entrenas por tu cuenta?",
    icon: BookOpen,
    slug: "suplementacion-esencial"
  },
  {
    title: "Espalda en Casa: Dominadas Sin Barra",
    description: "¿No puedes colgar una barra? Te enseñamos alternativas brutales para una espalda ancha.",
    icon: Flame,
    slug: "dominadas-sin-barra"
  }
];
---

<Layout title="Guías de Entrenamiento | MicroGym Elite" description="Aprende a entrenar con eficiencia. Rutinas, nutrición y consejos de expertos para maximizar tus resultados en casa.">
  <Navbar />
  
  <main class="pt-32">
    <section class="section-padding">
      <div class="container">
        <div class="max-w-3xl mb-16">
          <span class="text-primary font-black tracking-widest text-[10px] uppercase">CONOCIMIENTO ELITE</span>
          <h1 class="text-5xl md:text-6xl mt-4 mb-6">Guías de <span class="text-gradient">Entrenamiento</span></h1>
          <p class="text-text-muted text-xl leading-relaxed">
            La información es poder. Nuestras guías están diseñadas por profesionales para que no pierdas ni un segundo haciendo ejercicios inútiles.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          {guides.map(guide => (
            <a href={`/guias/${guide.slug}`} class="glass p-10 flex flex-col gap-6 hover:border-primary group transition-all">
              <div class="bg-primary/10 w-16 h-16 rounded-2xl flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
                <guide.icon size={32} />
              </div>
              <div>
                <h3 class="text-2xl mb-4 group-hover:text-primary transition-colors">{guide.title}</h3>
                <p class="text-text-muted leading-relaxed">{guide.description}</p>
              </div>
              <div class="mt-auto flex items-center gap-2 text-primary font-bold text-xs tracking-widest uppercase pt-4 border-t border-white/5">
                Leer Guía Completa <span class="group-hover:translate-x-2 transition-transform">→</span>
              </div>
            </a>
          ))}
        </div>

        <div class="mt-16">
          <AdSense type="in-feed" />
        </div>
      </div>
    </section>
  </main>

  <footer class="py-12 bg-surface/30 border-t border-white/5">
    <div class="container text-center text-text-dim text-[10px] tracking-widest uppercase">
      <p>&copy; 2024 MicroGym Elite. Maximiza tu potencial.</p>
    </div>
  </footer>
</Layout>
