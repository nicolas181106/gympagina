---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import AdSense from '../../components/AdSense.astro';

const posts = [
  {
    title: "5 Errores fatales al montar tu gimnasio en el salón",
    excerpt: "Evita estos fallos comunes que pueden arruinar tu entrenamiento y la convivencia en casa.",
    date: "24 Abr 2024",
    image: "/images/hero.png"
  },
  {
    title: "Cómo progresar en dominadas si no tienes barra",
    excerpt: "Ejercicios alternativos de tirón que puedes hacer con una simple toalla o una mesa fuerte.",
    date: "18 Abr 2024",
    image: "/images/dumbbells.png"
  },
  {
    title: "El mito de las 2000 calorías: ¿Cuánto comer realmente?",
    excerpt: "Aprende a calcular tus macros de forma sencilla según tu nivel de actividad real en casa.",
    date: "10 Abr 2024",
    image: "/images/hero.png"
  }
];
---

<Layout title="Blog de Fitness Urbano | MicroGym Elite" description="Artículos, noticias y reflexiones sobre el mundo del fitness en casa, nutrición y estilo de vida de alto rendimiento.">
  <Navbar />
  
  <main class="pt-32">
    <section class="section-padding">
      <div class="container">
        <div class="max-w-3xl mb-16">
          <span class="text-primary font-black tracking-widest text-[10px] uppercase">ACTUALIDAD Y CIENCIA</span>
          <h1 class="text-5xl md:text-6xl mt-4 mb-6">El Blog <span class="text-gradient">Elite</span></h1>
          <p class="text-text-muted text-xl leading-relaxed">
            Profundizamos en los temas que te interesan. Desde biomecánica aplicada hasta las últimas noticias sobre equipamiento inteligente.
          </p>
        </div>

        <div class="grid lg:grid-cols-3 gap-12">
          <div class="lg:col-span-2 space-y-16">
            {posts.map(post => (
              <article class="group">
                <div class="aspect-[16/9] rounded-2xl overflow-hidden mb-6 bg-surface border border-white/5">
                  <img src={post.image} alt={post.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                </div>
                <div class="flex items-center gap-4 text-[10px] font-black tracking-widest text-text-dim uppercase mb-4">
                  <span>{post.date}</span>
                  <span>•</span>
                  <span class="text-primary">Artículos</span>
                </div>
                <h2 class="text-3xl mb-4 group-hover:text-primary transition-colors cursor-pointer">{post.title}</h2>
                <p class="text-text-muted leading-relaxed mb-6">{post.excerpt}</p>
                <a href="#" class="text-xs font-black tracking-widest uppercase flex items-center gap-2 text-text hover:text-primary transition-colors">
                  Leer más →
                </a>
              </article>
            ))}
          </div>

          <aside class="space-y-12">
            
            <AdSense type="square" />

            <div class="glass p-8">
              <h3 class="text-xl mb-6">Categorías</h3>
              <ul class="space-y-4 text-sm text-text-muted font-bold">
                <li class="hover:text-primary cursor-pointer transition-colors flex justify-between items-center">
                  Entrenamiento <span>(12)</span>
                </li>
                <li class="hover:text-primary cursor-pointer transition-colors flex justify-between items-center">
                  Nutrición <span>(8)</span>
                </li>
                <li class="hover:text-primary cursor-pointer transition-colors flex justify-between items-center">
                  Gear Reviews <span>(15)</span>
                </li>
              </ul>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>

  <footer class="py-12 bg-surface/30 border-t border-white/5 text-center">
    <div class="container text-text-dim text-[10px] tracking-widest uppercase">
      <p>&copy; 2024 MicroGym Elite. Blog de autoridad.</p>
    </div>
  </footer>
</Layout>
