---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import AmazonProduct from "../../components/AmazonProduct.astro";
const analyses = [
  {
    title: "Mancuernas Ajustables Bowflex SelectTech 552",
    image: "/images/articulos/mancuernas_bowflex.jpg",
    link: "https://amzn.to/3QPWYS9",
    tag: "TOP VENTAS",
    slug: "bowflex-552",
  },
  {
    title: "Mancuernas Ativafit 25kg (Pareja)",
    image: "/images/dumbbells.png",
    link: "https://amzn.to/3example",
    tag: "CALIDAD/PRECIO",
    slug: "#",
  },
  {
    title: "Banco de Musculación Plegable Flybird",
    image: "/images/hero.png",
    link: "https://amzn.to/3example",
    tag: "INDISPENSABLE",
    slug: "banco-flybird",
  },
  {
    title: "Barra de Dominadas Extensible Premium",
    image: "/images/dumbbells.png",
    link: "https://amzn.to/3example",
    tag: "ECONÓMICO",
    slug: "#",
  },
  {
    title: "Bandas de Resistencia Set Completo",
    image: "/images/hero.png",
    link: "https://amzn.to/3example",
    tag: "MÁXIMO ESPACIO",
    slug: "#",
  },
];
---

<Layout
  title="Análisis de Equipamiento | MicroGym Elite"
  description="Reviews honestas del mejor equipamiento para gimnasios en casa pequeños. Mancuernas, bancos y racks analizados por expertos."
>
  <Navbar />

  <main class="pt-32">
    <section class="section-padding">
      <div class="container">
        <div class="max-w-3xl mb-16">
          <span
            class="text-primary font-black tracking-widest text-[10px] uppercase"
            >EQUIPAMIENTO PROBADO</span
          >
          <h1 class="text-5xl md:text-6xl mt-4 mb-6">
            Análisis de <span class="text-gradient">Gear</span>
          </h1>
          <p class="text-text-muted text-xl leading-relaxed">
            No malgastes tu dinero en equipo que estorba. Hemos probado y
            seleccionado las herramientas más eficientes para transformar
            cualquier habitación en un gimnasio de alto rendimiento.
          </p>
        </div>

        <div class="container mb-12"></div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {
            analyses.map((product) => (
              <AmazonProduct {...product} />
            ))
          }
        </div>

      </div>
    </section>

    <div class="container pb-24"></div>
  </main>

  <footer class="py-12 bg-surface/30 border-t border-white/5 text-center">
    <div class="container text-text-dim text-[10px] tracking-widest uppercase">
      <p>
        &copy; 2026 MicroGym Elite. Participamos en el Programa de Afiliados de
        Amazon.
      </p>
    </div>
  </footer>
</Layout>

