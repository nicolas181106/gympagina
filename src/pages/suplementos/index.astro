---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import AmazonProduct from '../../components/AmazonProduct.astro';
import AdSense from '../../components/AdSense.astro';

const supplements = [
  {
    title: "Creatina Monohidrato Creapure (500g)",
    price: "34€",
    rating: "5",
    image: "/images/hero.png",
    link: "https://amzn.to/3example",
    tag: "EL MEJOR SUPLEMENTO",
    slug: "creatina-guia"
  },
  {
    title: "Proteína Whey Isolada de Alta Calidad",
    price: "59€",
    rating: "5",
    image: "/images/hero.png",
    link: "https://amzn.to/3example",
    tag: "IMPRESCINDIBLE",
    slug: "proteina-suero-guia"
  },
  {
    title: "Pre-Entreno Explosivo sin Estimulantes",
    price: "29€",
    rating: "4",
    image: "/images/hero.png",
    link: "https://amzn.to/3example",
    tag: "PARA ENTRENAR TARDE",
    slug: "#"
  },
  {
    title: "Multivitamínico Completo para Atletas",
    price: "19€",
    rating: "5",
    image: "/images/hero.png",
    link: "https://amzn.to/3example",
    tag: "SALUD GENERAL",
    slug: "#"
  }
];
---

<Layout title="Guía de Suplementación Inteligente | MicroGym Elite" description="No tires el dinero en polvos mágicos. Te enseñamos qué suplementos funcionan de verdad para maximizar tus resultados entrenando en casa.">
  <Navbar />
  
  <main class="pt-32">
    <section class="section-padding">
      <div class="container">
        <div class="max-w-3xl mb-16">
          <span class="text-primary font-black tracking-widest text-[10px] uppercase">NUTRICIÓN BASADA EN EVIDENCIA</span>
          <h1 class="text-5xl md:text-6xl mt-4 mb-6">Suplementación <span class="text-gradient">Inteligente</span></h1>
          <p class="text-text-muted text-xl leading-relaxed">
            El 95% de los suplementos son puro marketing. En MicroGym Elite filtramos el ruido y te mostramos solo aquello que tiene evidencia científica y te ayudará a progresar.
          </p>
        </div>

        <div class="container mb-12">
          <AdSense type="banner" />
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {supplements.map(product => (
            <div class="flex flex-col gap-4">
              <AmazonProduct {...product} />
              {product.slug !== "#" && (
                <a href={`/suplementos/${product.slug}`} class="text-xs font-black tracking-widest uppercase flex items-center gap-2 text-text hover:text-primary transition-colors ml-2">
                  Leer Guía Completa →
                </a>
              )}
            </div>
          ))}
        </div>

        <div class="mt-24 grid lg:grid-cols-2 gap-16 items-center">
          <div class="glass p-12">
            <h2 class="text-3xl mb-6">¿Realmente los necesitas?</h2>
            <p class="text-text-muted mb-6">La respuesta corta es: <strong>Probablemente no</strong>, a menos que tu dieta y entrenamiento ya estén al 90% de perfección.</p>
            <p class="text-text-muted mb-8">Sin embargo, suplementos como la Creatina o la Proteína de suero pueden hacer que alcanzar tus objetivos sea mucho más sencillo y cómodo.</p>
            <ul class="space-y-4">
              <li class="flex items-center gap-3 text-sm font-bold"><span class="text-primary">✓</span> Creatina: Fuerza y recuperación.</li>
              <li class="flex items-center gap-3 text-sm font-bold"><span class="text-primary">✓</span> Proteína: Construcción muscular.</li>
              <li class="flex items-center gap-3 text-sm font-bold"><span class="text-primary">✓</span> Cafeína: Foco y rendimiento.</li>
            </ul>
          </div>
          <div>
            <AdSense type="square" />
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="py-12 bg-surface/30 border-t border-white/5 text-center">
    <div class="container text-text-dim text-[10px] tracking-widest uppercase">
      <p>&copy; 2024 MicroGym Elite. Suplementación con cabeza.</p>
    </div>
  </footer>
</Layout>
