---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import AdSense from '../../components/AdSense.astro';
import { Dumbbell, Zap, Target, Repeat } from 'lucide-astro';

const routines = [
  {
    title: "Full Body Minimalista (3 días)",
    level: "Principiante",
    duration: "45 min",
    focus: "Fuerza General",
    icon: Dumbbell,
    description: "La rutina ideal para quien solo tiene una pareja de mancuernas y poco tiempo.",
    slug: "fullbody-3-dias"
  },
  {
    title: "Push/Pull/Legs en Casa",
    level: "Intermedio",
    duration: "60 min",
    focus: "Hipertrofia",
    icon: Zap,
    description: "Divide tu entrenamiento para maximizar el crecimiento muscular con equipo básico.",
    slug: "push-pull-legs"
  },
  {
    title: "HIIT Quema-Grasa (Espacio Cero)",
    level: "Todos los niveles",
    duration: "20 min",
    focus: "Pérdida de Grasa",
    icon: Flame,
    description: "Sin equipo. Solo tú y el suelo. Ideal para días con prisas.",
    slug: "hiit-quema-grasa"
  },
  {
    title: "Powerlifting en Habitación",
    level: "Avanzado",
    duration: "90 min",
    focus: "Fuerza Máxima",
    icon: Target,
    description: "Cómo entrenar pesado en casa sin destrozar el suelo ni molestar a los vecinos.",
    slug: "#"
  }
];

import { Flame } from 'lucide-astro';
---

<Layout title="Rutinas de Entrenamiento en Casa | MicroGym Elite" description="Entrenamientos diseñados para maximizar resultados con el mínimo equipo. Rutinas de fuerza, hipertrofia y HIIT para tu gimnasio en casa.">
  <Navbar />
  
  <main class="pt-32">
    <section class="section-padding">
      <div class="container">
        <div class="max-w-3xl mb-16">
          <span class="text-primary font-black tracking-widest text-[10px] uppercase">PROGRAMAS DE ALTO RENDIMIENTO</span>
          <h1 class="text-5xl md:text-6xl mt-4 mb-6">Rutinas <span class="text-gradient">Explosivas</span></h1>
          <p class="text-text-muted text-xl leading-relaxed">
            No necesitas máquinas de 5000€ para mutar. Necesitas un plan inteligente y la disciplina para ejecutarlo. Elige tu objetivo y empieza hoy.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          {routines.map(routine => (
            <div class="glass p-8 flex flex-col gap-6 hover:border-primary group transition-all">
              <div class="flex justify-between items-start">
                <div class="bg-primary/10 p-4 rounded-xl text-primary group-hover:scale-110 transition-transform">
                  <routine.icon size={32} />
                </div>
                <span class="text-[10px] font-black tracking-tighter bg-white/5 px-3 py-1 rounded-full uppercase text-text-dim">
                  {routine.level}
                </span>
              </div>
              
              <div>
                <h3 class="text-2xl mb-2">{routine.title}</h3>
                <p class="text-text-muted text-sm leading-relaxed mb-6">{routine.description}</p>
                
                <div class="grid grid-cols-2 gap-4">
                  <div class="bg-surface p-3 rounded-lg border border-white/5">
                    <span class="text-[10px] text-text-dim block uppercase font-bold mb-1">Duración</span>
                    <span class="text-sm font-bold text-text">{routine.duration}</span>
                  </div>
                  <div class="bg-surface p-3 rounded-lg border border-white/5">
                    <span class="text-[10px] text-text-dim block uppercase font-bold mb-1">Objetivo</span>
                    <span class="text-sm font-bold text-text">{routine.focus}</span>
                  </div>
                </div>
              </div>

              <a href={`/rutinas/${routine.slug}`} class="btn btn-primary w-full text-center py-3 text-xs">
                Ver Rutina Completa
              </a>
            </div>
          ))}
        </div>

        <div class="mt-16">
          <AdSense type="in-feed" />
        </div>
      </div>
    </section>
  </main>

  <footer class="py-12 bg-surface/30 border-t border-white/5">
    <div class="container text-center text-text-dim text-[10px] tracking-widest uppercase">
      <p>&copy; 2026 MicroGym Elite. Sin excusas.</p>
    </div>
  </footer>
</Layout>
